<file path="_sass/_base.scss">
/**
 * Reset some basic elements
 */
body, h1, h2, h3, h4, h5, h6,
p, blockquote, pre, hr,
dl, dd, ol, ul, figure {
    margin: 0;
    padding: 0;
}



/**
 * Basic styling
 */
 body {
    font-family: $base-font-family;
    font-size: 17px; // 建議將基礎字體從 16px 提升到 17px，中文看起來更清楚
    line-height: 1.8; // 中文建議使用 1.7 ~ 1.8 (英文通常是 1.5)
    font-weight: 400; // 確保字體有足夠的粗細，深色背景下太細會看不清楚
    color: $text-color;
    background-color: $background-color;
    -webkit-text-size-adjust: 100%;
    
    /* 新增：微調字距，讓中文字不要黏在一起 */
    letter-spacing: 0.03em; 
    
    /* 新增：優化文字渲染，讓字體在 Mac/iOS 上更清晰 */
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;

    @include media-query($on-palm) {
        font-size: 16px; // 手機版稍微縮小一點點
        line-height: 1.75;
    }
}




/**
 * Set `margin-bottom` to maintain vertical rhythm
 */
h1, h2, h3, h4, h5, h6,
p, blockquote, pre,
ul, ol, dl, figure,
%vertical-rhythm {
    margin-bottom: $spacing-unit / 2;
}



/**
 * Images
 */
img {
    display: block;
    margin-left: auto;
    margin-right: auto;
    max-width: 100%; /* 修改：從 80% 改為 100%，讓圖片在手機上能滿版顯示 */
    height: auto;    /* 新增：確保圖片比例不變 */

    /* 如果你希望桌面版維持 80%，可以保留原本設定並加上這段： */
    @include media-query($on-laptop) {
        max-width: 100%;
    }
}

/**
 * Tables
 * 手機上表格容易破版，加入 overflow-x 讓表格可以左右滑動
 */
table {
    border-collapse: collapse;
    width: 100%;
    display: block;       /* 新增：讓表格變成區塊元素以便滑動 */
    overflow-x: auto;     /* 新增：內容過寬時出現卷軸 */
    -webkit-overflow-scrolling: touch; /* 新增：iOS 滑動更順暢 */
    word-wrap: normal;    /* 修改：避免文字在不該斷的地方斷行 */
    word-break: normal;
}

th, td {
    border: 1px solid #fdfdfd;
    text-align: center;
    padding: 4px;
}


/**
 * Figures
 */
figure > img {
    display: block;
}

figcaption {
    font-size: $small-font-size;
}



/**
 * Lists
 */
ul, ol {
    margin-left: $spacing-unit;
}

li {
    > ul,
    > ol {
         margin-bottom: 0;
    }
}



/**
 * Headings
 */
h1, h2, h3, h4, h5, h6 {
    font-weight: 300;
}



/**
 * Links
 */
 a {
    color: $brand-color;
    text-decoration: none;
    transition: color 0.2s ease-in-out; // 新增平滑過渡

    &:visited {
        color: lighten($brand-color, 5%); // 稍微調亮，不要變太暗
    }

    &:hover {
        color: lighten($brand-color, 20%); // 懸停時變亮
        text-decoration: none; // 去除底線，看起來較乾淨 (視個人喜好)
    }
}




/**
 * Blockquotes
 */
 blockquote {
    color: lighten($grey-color, 10%);
    border-left: 4px solid $brand-color; // 左側邊框改用品牌色
    padding-left: 20px;
    padding-top: 5px;
    padding-bottom: 5px;
    margin-bottom: 30px;
    background-color: rgba(255, 255, 255, 0.05); // 淡淡的背景色
    border-radius: 0 5px 5px 0;
    
    font-size: 16px; // 字體稍小
    font-style: normal; // 重點：取消斜體！
    letter-spacing: 0.03em;
    
    > :last-child {
        margin-bottom: 0;
    }
}

/**
 * Code formatting
 */
 pre,
 code {
     font-family: "Menlo", "Consolas", "Monaco", monospace; // 程式碼專用字體
     font-size: 15px;
     border-radius: 6px; // 圓角
     border: 1px solid #444; // 深色邊框
     background-color: #2b2b2b; // 改為深色背景
     color: #f8f8f2; // 程式碼預設文字改為淺色
 }
 
 code {
     padding: 2px 6px;
 }
 
 pre {
     padding: 15px;
     overflow-x: auto;
     box-shadow: inset 0 0 10px rgba(0,0,0,0.3); // 內部陰影增加層次
 
     > code {
         border: 0;
         padding-right: 0;
         padding-left: 0;
         background-color: transparent; // 避免雙重背景
     }
 }
 



/**
 * Wrapper
 */
.wrapper {
    max-width: -webkit-calc(800px - (#{$spacing-unit} * 2));
    max-width:         calc(800px - (#{$spacing-unit} * 2));
    margin-right: auto;
    margin-left: auto;
    padding-right: $spacing-unit;
    padding-left: $spacing-unit;
    @extend %clearfix;

    @include media-query($on-laptop) {
        max-width: -webkit-calc(800px - (#{$spacing-unit}));
        max-width:         calc(800px - (#{$spacing-unit}));
        padding-right: $spacing-unit / 2;
        padding-left: $spacing-unit / 2;
    }

    /* 新增：針對手機版 ($on-palm) 再縮小邊距，爭取更多閱讀空間 */
    @include media-query($on-palm) {
        padding-right: 15px; 
        padding-left: 15px;
    }
}


/**
 * Clearfix
 */
%clearfix {

    &:after {
        content: "";
        display: table;
        clear: both;
    }
}



/**
 * Icons
 */
.icon {

    > svg {
        display: inline-block;
        width: 16px;
        height: 16px;
        vertical-align: middle;

        path {
            fill: $grey-color;
        }
    }
}

iframe[src*="youtube"] {
    display: block;
    width: 100%;           /* 寬度隨螢幕縮放 */
    max-width: 100%;       /* 確保不超出容器 */
    height: auto;          /* 覆寫原本的高度設定 */
    aspect-ratio: 16 / 9;  /* 強制維持 16:9 的影片比例 */
    margin-bottom: 30px;   /* 保持垂直韻律 */
}
</file>

<file path="_sass/_layout.scss">
/**
 * Site header
 */
 .site-header {
    // border-top: 5px solid $grey-color-dark; // 建議註解掉或刪除這行
    border-bottom: none; // 移除底部線條，改用陰影
    min-height: 56px;
    position: relative;
    background-color: rgba($background-color, 0.95); // 稍微透明
    backdrop-filter: blur(5px); // 磨砂玻璃效果 (現代瀏覽器支援)
    box-shadow: 0 1px 10px rgba(0,0,0,0.5); // 增加底部陰影
    
    // 讓 Header 在手機版更乾淨
    @include media-query($on-palm) {
        position: sticky; // 讓選單黏在頂部 (選用)
        top: 0;
        z-index: 1000;
    }
}

.site-title {
    font-weight: 700;
    font-size: 26px;
    line-height: 56px;
    letter-spacing: -1px;
    margin-bottom: 0;
    float: left;

    &,
    &:visited {
        color: $grey-color;
    }

    /* 新增：手機上若標題太長，稍微縮小字體 */
    @include media-query($on-palm) {
        font-size: 22px;
        margin-right: 10px; /* 避免跟漢堡選單重疊 */
    }
}

.site-nav {
    float: right;
    line-height: 56px;

    /* ... (中間 .menu-icon 等代碼保持不變) ... */

    @include media-query($on-palm) {
        position: absolute;
        top: 9px;
        right: 15px; /* 修改：配合 wrapper 的 padding 調整 */
        background-color: $background-color;
        border: 1px solid $grey-color-light;
        border-radius: 5px;
        text-align: right;
        z-index: 999; /* 新增：確保選單浮在最上層 */

        .menu-icon {
            display: block;
            float: right;
            width: 36px;
            height: 26px;
            line-height: 0;
            padding-top: 10px;
            text-align: center;
            cursor: pointer; /* 新增：增加點擊手感提示 */

            > svg {
                width: 18px;
                height: 15px;
                path {
                    fill: $grey-color-dark;
                }
            }
        }

        .trigger {
            clear: both;
            display: none;
        }

        /* 
         * 注意：原本的代碼使用 :hover 來顯示選單。
         * 在手機上 :hover 體驗不佳，但如果沒有 JavaScript，
         * 這是純 CSS 的妥協做法。建議將 padding 加大以便點擊。
         */
        &:hover .trigger {
            display: block;
            padding-bottom: 5px;
        }

        .page-link {
            display: block;
            padding: 10px 20px; /* 修改：加大點擊範圍 */
            margin-left: 0; /* 重置 margin */
            
            &:not(:first-child) {
                margin-left: 0;
            }
        }
    }
}


/**
 * Site footer
 */
.site-footer {
    border-top: 1px solid $grey-color-light;
    padding: $spacing-unit 0;
}

.footer-heading {
    font-size: 18px;
    margin-bottom: $spacing-unit / 2;
}

.contact-list,
.social-media-list {
    list-style: none;
    margin-left: 0;
}

.footer-col-wrapper {
    font-size: 15px;
    color: $grey-color;
    margin-left: -$spacing-unit / 2;
    @extend %clearfix;
}

.footer-col {
    float: left;
    margin-bottom: $spacing-unit / 2;
    padding-left: $spacing-unit / 2;
}

.footer-col-1 {
    width: -webkit-calc(35% - (#{$spacing-unit} / 2));
    width:         calc(35% - (#{$spacing-unit} / 2));
}

.footer-col-2 {
    width: -webkit-calc(20% - (#{$spacing-unit} / 2));
    width:         calc(20% - (#{$spacing-unit} / 2));
}

.footer-col-3 {
    width: -webkit-calc(45% - (#{$spacing-unit} / 2));
    width:         calc(45% - (#{$spacing-unit} / 2));
}

@include media-query($on-laptop) {
    .footer-col-1,
    .footer-col-2 {
        width: -webkit-calc(50% - (#{$spacing-unit} / 2));
        width:         calc(50% - (#{$spacing-unit} / 2));
    }

    .footer-col-3 {
        width: -webkit-calc(100% - (#{$spacing-unit} / 2));
        width:         calc(100% - (#{$spacing-unit} / 2));
    }
}

@include media-query($on-palm) {
    .footer-col {
        float: none;
        width: -webkit-calc(100% - (#{$spacing-unit} / 2));
        width:         calc(100% - (#{$spacing-unit} / 2));
    }
}



/**
 * Page content
 */
.page-content {
    padding: $spacing-unit 0;
}

.page-heading {
    font-size: 20px;
}

.post-list {
    margin-left: 0;
    list-style: none;

    > li {
        margin-bottom: $spacing-unit;
        
        /* --- 新增卡片樣式 --- */
        background-color: $card-bg-color; // 使用剛剛新增的變數 (若未新增可直接寫 #2d2d30)
        padding: 25px;
        border-radius: 12px; // 圓角
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3); // 陰影增加立體感
        transition: transform 0.2s ease, box-shadow 0.2s ease; // 動畫過渡
        border: 1px solid lighten($background-color, 10%); // 微妙的邊框

        // 滑鼠懸停效果
        &:hover {
            transform: translateY(-5px); // 稍微浮起
            box-shadow: 0 10px 15px rgba(0, 0, 0, 0.4);
            border-color: $brand-color; // 懸停時邊框變色
        }
    }

    /* 調整卡片內的標題與日期 */
    h2 {
        margin-top: 5px;
        font-size: 24px;
        a {
            color: #fff;
            text-decoration: none;
            &:hover { color: $brand-color; }
        }
    }
}

.post-meta {
    font-size: 14px;
    color: $grey-color;
    text-transform: uppercase; // 日期改為全大寫看起來較整齊
    letter-spacing: 1px;
}

.post-link {
    display: block;
    font-size: 24px;
}



/**
 * Posts
 */
.post-header {
    margin-bottom: $spacing-unit;
}

.post-title {
    font-size: 42px;
    letter-spacing: -1px;
    line-height: 1;

    @include media-query($on-laptop) {
        font-size: 36px;
    }
    
    /* 新增：手機版標題再縮小一點，避免斷行太嚴重 */
    @include media-query($on-palm) {
        font-size: 28px;
    }
}

.post-content {
    margin-bottom: $spacing-unit;

    // 針對所有標題 (h1~h6) 增加上方距離，區分段落層級
    h2, h3, h4, h5, h6 {
        margin-top: 40px; // 標題上方留白
        margin-bottom: 20px;
        font-weight: 700;
        line-height: 1.4;
        color: #fff; // 標題用全白，與內文灰白區隔
    }

    // 針對段落 p
    p {
        margin-bottom: 28px; // 段落之間距離加大
        text-align: justify; // 左右對齊 (讓右邊緣整齊，不會參差不齊)
        text-justify: inter-ideograph; // 針對中文字的對齊優化
    }

    // 針對列表
    ul, ol {
        margin-bottom: 25px;
        li {
            margin-bottom: 10px; // 列表項目之間也要有點距離
            line-height: 1.7;
        }
    }
    
    // 強調文字 (Bold)
    strong {
        color: #fff; // 強調文字變亮白
        font-weight: 700;
    }
}
</file>

<file path="_sass/_syntax-highlighting.scss">
/**
 * Syntax highlighting styles
 */
.highlight {
    background: #fff;
    @extend %vertical-rhythm;

    .c     { color: #998; font-style: italic } // Comment
    .err   { color: #a61717; background-color: #e3d2d2 } // Error
    .k     { font-weight: bold } // Keyword
    .o     { font-weight: bold } // Operator
    .cm    { color: #998; font-style: italic } // Comment.Multiline
    .cp    { color: #999; font-weight: bold } // Comment.Preproc
    .c1    { color: #998; font-style: italic } // Comment.Single
    .cs    { color: #999; font-weight: bold; font-style: italic } // Comment.Special
    .gd    { color: #000; background-color: #fdd } // Generic.Deleted
    .gd .x { color: #000; background-color: #faa } // Generic.Deleted.Specific
    .ge    { font-style: italic } // Generic.Emph
    .gr    { color: #a00 } // Generic.Error
    .gh    { color: #999 } // Generic.Heading
    .gi    { color: #000; background-color: #dfd } // Generic.Inserted
    .gi .x { color: #000; background-color: #afa } // Generic.Inserted.Specific
    .go    { color: #888 } // Generic.Output
    .gp    { color: #555 } // Generic.Prompt
    .gs    { font-weight: bold } // Generic.Strong
    .gu    { color: #aaa } // Generic.Subheading
    .gt    { color: #a00 } // Generic.Traceback
    .kc    { font-weight: bold } // Keyword.Constant
    .kd    { font-weight: bold } // Keyword.Declaration
    .kp    { font-weight: bold } // Keyword.Pseudo
    .kr    { font-weight: bold } // Keyword.Reserved
    .kt    { color: #458; font-weight: bold } // Keyword.Type
    .m     { color: #099 } // Literal.Number
    .s     { color: #d14 } // Literal.String
    .na    { color: #008080 } // Name.Attribute
    .nb    { color: #0086B3 } // Name.Builtin
    .nc    { color: #458; font-weight: bold } // Name.Class
    .no    { color: #008080 } // Name.Constant
    .ni    { color: #800080 } // Name.Entity
    .ne    { color: #900; font-weight: bold } // Name.Exception
    .nf    { color: #900; font-weight: bold } // Name.Function
    .nn    { color: #555 } // Name.Namespace
    .nt    { color: #000080 } // Name.Tag
    .nv    { color: #008080 } // Name.Variable
    .ow    { font-weight: bold } // Operator.Word
    .w     { color: #bbb } // Text.Whitespace
    .mf    { color: #099 } // Literal.Number.Float
    .mh    { color: #099 } // Literal.Number.Hex
    .mi    { color: #099 } // Literal.Number.Integer
    .mo    { color: #099 } // Literal.Number.Oct
    .sb    { color: #d14 } // Literal.String.Backtick
    .sc    { color: #d14 } // Literal.String.Char
    .sd    { color: #d14 } // Literal.String.Doc
    .s2    { color: #d14 } // Literal.String.Double
    .se    { color: #d14 } // Literal.String.Escape
    .sh    { color: #d14 } // Literal.String.Heredoc
    .si    { color: #d14 } // Literal.String.Interpol
    .sx    { color: #d14 } // Literal.String.Other
    .sr    { color: #009926 } // Literal.String.Regex
    .s1    { color: #d14 } // Literal.String.Single
    .ss    { color: #990073 } // Literal.String.Symbol
    .bp    { color: #999 } // Name.Builtin.Pseudo
